#include <stdio.h>
#include <math.h>

int main() {
    int i, n;
    float x, degree, term, sum;

    printf("Enter the angle in degrees: ");
    scanf("%f", &degree);

    printf("Enter the number of terms: ");
    scanf("%d", &n);

    // Convert degree to radians
    x = degree * (3.14159 / 180.0);

    // Initializations
    term = x;  // First term of the series is x
    sum = x;   // Initial sum is the first term

    for (i = 1; i < n; i++) {
        
        term = term * (-1 * x * x) / ((2 * i) * (2 * i + 1));
        sum = sum + term;
    }

    printf("\nSum of the sine series up to %d terms: %f", n, sum);
    printf("\nValue using library function sin(%f): %f\n", degree, sin(x));

    return 0;
}
