'''
#include <stdio.h>
int find_smallest_divisor(int n) {
    if (n < 2) return n;
    for (int i = 2; i <= n; i++) {
        if (n % i == 0) return i;
    }
    return n;
}
int find_gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}
int main() {
    int num1, num2;
    printf("Enter two positive integers: ");
    if (scanf("%d %d", &num1, &num2) != 2 || num1 <= 0 || num2 <= 0) {
        printf("Invalid input. Please enter positive integers.\n");
        return 1;
    }
    printf("Smallest divisor of %d: %d\n", num1, find_smallest_divisor(num1));
    printf("Smallest divisor of %d: %d\n", num2, find_smallest_divisor(num2));
    printf("GCD of %d and %d: %d\n", num1, num2, find_gcd(num1, num2));
    return 0;
}
