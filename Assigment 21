''' Q21)
#include <stdio.h>
#include <stdlib.h>

int main() {
    FILE *sourceFile, *destFile;
    char sourcePath[100], destPath[100];
    char ch;

    // Input file paths from user
    printf("Enter source file path: ");
    scanf("%s", sourcePath);
    printf("Enter destination file path: ");
    scanf("%s", destPath);

    // 1. Open source file in 'read' mode
    sourceFile = fopen(sourcePath, "r");
    if (sourceFile == NULL) {
        printf("Error: Cannot open source file %s\n", sourcePath);
        exit(EXIT_FAILURE);
    }

    // 2. Open destination file in 'write' mode
    destFile = fopen(destPath, "w");
    if (destFile == NULL) {
        printf("Error: Cannot open destination file %s\n", destPath);
        fclose(sourceFile); // Close source before exiting
        exit(EXIT_FAILURE);
    }

    // 3. Copy contents character by character
    // fgetc returns EOF (End Of File) when it reaches the end
    while ((ch = fgetc(sourceFile)) != EOF) {
        fputc(ch, destFile);
    }

    printf("\nFile copied successfully from %s to %s\n", sourcePath, destPath);

    // 4. Close both files to release memory
    fclose(sourceFile);
    fclose(destFile);

    return 0;
}
'''