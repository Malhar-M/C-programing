'''
#include <stdio.h>
void main() {
    int num, fact = 1;
    printf("Enter a number: ");
    scanf("%d", &num);
    if (num == 0) { 
        printf("Factorial is 1");
    } 
    else if (num < 0) {
        printf("Invalid input");
    } 
    else {
        for (int i = num; i >= 1; i--) {
            fact *= i;
        }
        printf("Factorial of %d is %d", num, fact);
    }
}
