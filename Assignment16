        } else {
            odd[oCount] = a[i];
            oCount++;
        }
    }
    printf("\nEven numbers: ");
    for(int i = 0; i < eCount; i++) {
        printf("%d ", even[i]);
    }
    printf("\nOdd numbers: ");
    for(int i = 0; i < oCount; i++) {
        printf("%d ", odd[i]);
    }
    printf("\n");
}
