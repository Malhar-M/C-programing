#include <stdio.h>
//FIBONACCI 
int fib(int n) {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

int main() {
    int num;
    printf("Enter the number: ");
    scanf("%d", &num);

    for (int i = 0; i <= num; i++) {
        printf("%d\n", fib(i));
    }

    return 0;
}

