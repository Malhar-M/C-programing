'''q19
#include <stdio.h>
#include <string.h>

struct Date {
    int day;
    int month;
    int year;
};

struct Employee {
    char name[50];
    char designation[50];
    char gender; // 'M' or 'F'
    struct Date doj;
    float salary;
};

void printEmployee(struct Employee emp) {
    printf("\nName: %s", emp.name);
    printf("Designation: %s", emp.designation);
    printf("Gender: %c\n", emp.gender);
    printf("DOJ: %02d/%02d/%0d\n", emp.doj.day, emp.doj.month, emp.doj.year);
    printf("Salary: %.2f\n", emp.salary);
}

int main() {
    int n, i;
    int maleCount = 0, femaleCount = 0;

    printf("How many employees are in the organization? ");
    scanf("%d", &n);
    getchar(); // consume newline

    struct Employee staff[n];

    for (i = 0; i < n; i++) {
        printf("\n--- Entering Details for Employee %d ---\n", i + 1);
        
        printf("Name: ");
        fgets(staff[i].name, sizeof(staff[i].name), stdin);
        staff[i].name[strcspn(staff[i].name, "\n")] = 0;

        printf("Designation: ");
        fgets(staff[i].designation, sizeof(staff[i].designation), stdin);
        staff[i].designation[strcspn(staff[i].designation, "\n")] = 0;

        printf("Gender (M/F): ");
        scanf(" %c", &staff[i].gender);

        printf("Date of Joining (DD MM YYYY): ");
        scanf("%d %d %d", &staff[i].doj.day, &staff[i].doj.month, &staff[i].doj.year);

        printf("Salary: ");
        scanf("%f", &staff[i].salary);
        getchar(); // cleanup buffer
    }

    // A) Total number of employees
    printf("\n========================================");
    printf("\nTotal number of employees: %d\n", n);

    // B) Count of male and female
    for (i = 0; i < n; i++) {
        if (staff[i].gender == 'M' || staff[i].gender == 'm')
            maleCount++;
        else if (staff[i].gender == 'F' || staff[i].gender == 'f')
            femaleCount++;
    }
    printf("Male Employees: %d\n", maleCount);
    printf("Female Employees: %d\n", femaleCount);

    // C) Salary more than 10,000
    printf("\n--- Employees with Salary > 10,000 ---");
    int foundSalary = 0;
    for (i = 0; i < n; i++) {
        if (staff[i].salary > 10000) {
            printEmployee(staff[i]);
            foundSalary = 1;
        }
    }
    if (!foundSalary) printf("\nNone found.\n");

    // D) Designation "Asst Manager"
    printf("\n--- Employees with Designation 'Asst Manager' ---");
    int foundDesig = 0;
    for (i = 0; i < n; i++) {
        if (strcasecmp(staff[i].designation, "Asst Manager") == 0) {
            printEmployee(staff[i]);
            foundDesig = 1;
        }
    }
    if (!foundDesig) printf("\nNone found.\n");

    return 0;
}
'''